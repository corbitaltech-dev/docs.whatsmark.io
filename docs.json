            "group": "OTP",
            "pages": ["POST /api/v1/otp", "GET /api/v1/otp/{reference}", "DELETE /api/v1/otp/{reference}", "POST /api/v1/otp/{reference}/verify", "POST /api/v1/otp/{reference}/resend"]
